{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stygian/schemas/github/issue.schema.json",
  "title": "Issue",
  "description": "A GitHub issue record",
  "type": "object",
  "required": ["id", "number", "title", "url", "state"],
  "properties": {
    "id": { "type": "string", "description": "GitHub global node ID" },
    "number": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "state": { "type": "string", "enum": ["OPEN", "CLOSED"] },
    "author": {
      "type": ["object", "null"],
      "properties": {
        "login": { "type": "string" }
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "color": { "type": "string" }
        }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
