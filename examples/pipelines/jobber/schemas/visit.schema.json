{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycelium/schemas/jobber/visit.schema.json",
  "title": "Visit",
  "description": "A Jobber visit (scheduled appointment) record",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "startAt": { "type": "string", "format": "date-time" },
    "endAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "allDay": { "type": "boolean" },
    "isDefaultTitle": { "type": "boolean" },
    "job": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
